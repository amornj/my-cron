#!/usr/bin/env python3
"""
daily-cron: Run daily tweet summary, market briefing, and weather report.
Usage: daily-cron
"""
import subprocess
import sys
import json

def run_job(name, command):
    print(f"\n{'='*50}")
    print(f"Running: {name}")
    print('='*50)
    result = subprocess.run(command, shell=True, capture_output=False)
    if result.returncode != 0:
        print(f"[FAIL] {name} exited with code {result.returncode}")
        return False
    print(f"[OK] {name} completed")
    return True

def main():
    print("Starting daily cron jobs...")
    
    jobs = [
        ("Echo: Daily Tweet Summary", 
         'openclaw cron run 31955083-b9f1-422a-9b22-386720664d1a'),
        ("Daily Market Briefing", 
         'openclaw cron run f0dbfd62-3364-423a-86cd-bb137c7897fc'),
        ("Daily Bangkok Weather", 
         'openclaw cron run 01da9cef-beee-4ae1-acaf-8e877504f7c0'),
    ]
    
    results = {}
    for name, cmd in jobs:
        results[name] = run_job(name, cmd)
    
    print(f"\n{'='*50}")
    print("SUMMARY")
    print('='*50)
    for name, ok in results.items():
        status = "✅" if ok else "❌"
        print(f"{status} {name}")
    
    all_ok = all(results.values())
    sys.exit(0 if all_ok else 1)

if __name__ == "__main__":
    main()
